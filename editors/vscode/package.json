{
  "name": "vivi-lang",
  "displayName": "Vivi Language",
  "description": "Language support for Vivi ECS language — syntax highlighting, go-to-definition, hover",
  "version": "0.1.0",
  "publisher": "vivi",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": ["Programming Languages"],
  "main": "./extension.js",
  "activationEvents": ["onLanguage:vivi"],
  "contributes": {
    "languages": [
      {
        "id": "vivi",
        "aliases": ["Vivi", "vivi"],
        "extensions": [".vivi"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "vivi",
        "scopeName": "source.vivi",
        "path": "../vivi.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Vivi",
      "properties": {
        "vivi.lspPath": {
          "type": "string",
          "default": "vivi-lsp",
          "description": "Path to vivi-lsp executable"
        }
      }
    }
  }
}
